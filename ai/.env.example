# Modèle MedGemma à charger (nécessite d'accepter la licence sur Hugging Face)
MEDGEMMA_MODEL=google/medgemma-4b-it

# Mode mock : 1 = renvoie une analyse factice sans charger le modèle (dev front/back)
AI_MOCK=1

# Origines autorisées (CORS), séparées par des virgules
# Appelé en serveur-à-serveur par Django (8000) ; 8501 = front Streamlit en direct.
AI_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8501

# Token Hugging Face si le modèle est gated (sinon `huggingface-cli login`)
# HF_TOKEN=hf_xxx
